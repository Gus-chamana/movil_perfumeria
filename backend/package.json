{
  "name": "noir-essence-backend",
  "version": "1.0.0",
  "description": "Backend API for Noir Essence Luxury Perfume E-commerce Mobile App",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "supabase",
