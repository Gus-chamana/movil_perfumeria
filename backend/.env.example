PORT=3000
JWT_SECRET=reemplazar_con_un_secreto_seguro_y_largo

# Conexión a la base de datos de Supabase (PostgreSQL)
# DATABASE_URL se usa para consultas regulares (Connection Pooling a través de puerto 6543)
# DIRECT_URL se usa para migraciones (Conexión directa a través de puerto 5432)
DATABASE_URL="postgresql://postgres.[ID_PROYECTO]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ID_PROYECTO]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
