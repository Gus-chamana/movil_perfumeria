generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model atributo_valores {
  id                 String               @id
  atributo_id        String
  valor              String
  atributos          atributos            @relation(fields: [atributo_id], references: [id], onDelete: Cascade)
  variante_atributos variante_atributos[]

  @@unique([atributo_id, valor])
}

model atributos {
  id               String             @id
  nombre           String             @unique
  atributo_valores atributo_valores[]
}

model carrito {
  id            String          @id
  usuario_id    String          @unique
  created_at    DateTime        @default(now())
  updated_at    DateTime
  usuarios      usuarios        @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  carrito_items carrito_items[]
}

model carrito_items {
  id                   String             @id
  carrito_id           String
  producto_variante_id String
  cantidad             Int                @default(1)
  carrito              carrito            @relation(fields: [carrito_id], references: [id], onDelete: Cascade)
  producto_variantes   producto_variantes @relation(fields: [producto_variante_id], references: [id], onDelete: Cascade)

  @@unique([carrito_id, producto_variante_id])
}

model datos_personales {
  id               String   @id
  usuario_id       String   @unique
  nombre           String
  apellido_paterno String
  apellido_materno String?
  dni              String   @unique
  created_at       DateTime @default(now())
  updated_at       DateTime
  usuarios         usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model detalle_orden {
  id                   String             @id
  orden_id             String
  producto_variante_id String
  cantidad             Int
  precio_unitario      Decimal            @db.Decimal(10, 2)
  ordenes              ordenes            @relation(fields: [orden_id], references: [id], onDelete: Cascade)
  producto_variantes   producto_variantes @relation(fields: [producto_variante_id], references: [id])
}

model direcciones {
  id           String   @id
  usuario_id   String
  direccion    String
  departamento String
  provincia    String
  distrito     String
  referencia   String?
  es_principal Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime
  usuarios     usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
}

model envio_estados {
  id       String      @id
  envio_id String
  estado   OrderStatus
  fecha    DateTime    @default(now())
  envios   envios      @relation(fields: [envio_id], references: [id], onDelete: Cascade)
}

model envios {
  id              String          @id
  orden_id        String          @unique
  motorizado_id   String?
  numero_tracking String          @unique
  estado_actual   OrderStatus     @default(CREADO)
  tiempo_estimado String?
  created_at      DateTime        @default(now())
  updated_at      DateTime
  envio_estados   envio_estados[]
  motorizados     motorizados?    @relation(fields: [motorizado_id], references: [id])
  ordenes         ordenes         @relation(fields: [orden_id], references: [id], onDelete: Cascade)
}

model favoritos {
  usuario_id  String
  producto_id String
  productos   productos @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  usuarios    usuarios  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@id([usuario_id, producto_id])
}

model motorizados {
  id             String   @id
  nombre         String
  telefono       String
  placa_vehiculo String
  activo         Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime
  envios         envios[]
  usuarios       usuarios @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ordenes {
  id              String          @id
  usuario_id      String
  estado          OrderStatus     @default(CREADO)
  precio_total    Decimal         @db.Decimal(10, 2)
  direccion_envio String
  receptor_nombre String
  receptor_dni    String
  created_at      DateTime        @default(now())
  updated_at      DateTime
  detalle_orden   detalle_orden[]
  envios          envios?
  usuarios        usuarios        @relation(fields: [usuario_id], references: [id])
  pagos           pagos?
}

model pagos {
  id             String        @id
  orden_id       String        @unique
  metodo_pago    PaymentMethod
  monto          Decimal       @db.Decimal(10, 2)
  estado         PaymentStatus @default(PENDIENTE)
  fecha_pago     DateTime      @default(now())
  transaccion_id String?
  ordenes        ordenes       @relation(fields: [orden_id], references: [id], onDelete: Cascade)
}

model producto_variantes {
  id                 String               @id
  producto_id        String
  sku                String               @unique
  precio             Decimal              @db.Decimal(10, 2)
  stock              Int
  imagen_url         String?
  created_at         DateTime             @default(now())
  updated_at         DateTime
  carrito_items      carrito_items[]
  detalle_orden      detalle_orden[]
  productos          productos            @relation(fields: [producto_id], references: [id], onDelete: Cascade)
  variante_atributos variante_atributos[]
}

model productos {
  id                 String               @id
  nombre             String
  marca              String
  descripcion        String
  es_nuevo           Boolean              @default(false)
  categoria          String
  gender             String               @default("unisex")
  created_at         DateTime             @default(now())
  updated_at         DateTime
  favoritos          favoritos[]
  producto_variantes producto_variantes[]
}

model usuarios {
  id               String            @id
  email            String            @unique
  password         String            @db.VarChar(255)
  rol              Role              @default(CLIENTE)
  created_at       DateTime          @default(now())
  updated_at       DateTime
  carrito          carrito?
  datos_personales datos_personales?
  direcciones      direcciones[]
  favoritos        favoritos[]
  motorizados      motorizados?
  ordenes          ordenes[]
}

model variante_atributos {
  producto_variante_id String
  atributo_valor_id    String
  atributo_valores     atributo_valores   @relation(fields: [atributo_valor_id], references: [id], onDelete: Cascade)
  producto_variantes   producto_variantes @relation(fields: [producto_variante_id], references: [id], onDelete: Cascade)

  @@id([producto_variante_id, atributo_valor_id])
}

enum OrderStatus {
  CREADO
  PREPARANDO
  EN_RUTA
  ENTREGADO
}

enum PaymentMethod {
  YAPE
  PLIN
  TARJETA
}

enum PaymentStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum Role {
  CLIENTE
  ADMIN
  MOTORIZADO
}
